{
  "description": "Sets release as the base branch. Automerges minor and patch updates, keeping major updates for manual review. Pins strip-ansi to avoid its ESM-only release. Runs on weekday nights. Merges up to 5 PRs per hour and 2 concurrently.",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": ["release"],
  "automerge": true,
  "major": {
    "automerge": false
  },
  "minor": {
    "automerge": true
  },
  "separateMultipleMajor": true,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchDepTypes": ["peerDependencies", "engines"],
      "rangeStrategy": "widen"
    },
    {
      "matchPackageNames": ["strip-ansi"],
      "enabled": false
    }
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "prCreation": "not-pending",
  "minimumReleaseAge": "3 days",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 2,
  "rebaseWhen": "behind-base-branch",
  "timezone": "Europe/Madrid",
  "schedule": ["* 21-23 * * 1-5", "* 0-16 * * 1-5"],
  "dependencyDashboard": true
}

