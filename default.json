{
  "description": "Sets release as the base branch. Groups all minor updates into one PR and all patch updates into another; major updates are separate, one PR each. Pins strip-ansi to avoid its ESM-only release. Holds updates until 3 days after release. No time-of-day schedule. Up to 2 open PRs and 4 branches at once. No automerge - all PRs are left for manual review.",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": ["release"],
  "separateMultipleMajor": true,
  "separateMinorPatch": true,
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchDepTypes": ["peerDependencies", "engines"],
      "rangeStrategy": "widen"
    },
    {
      "matchPackageNames": ["strip-ansi"],
      "enabled": false
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "all minor dependencies",
      "groupSlug": "all-minor"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "all patch dependencies",
      "groupSlug": "all-patch"
    }
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "minimumReleaseAge": "3 days",
  "prHourlyLimit": 5,
  "prConcurrentLimit": 2,
  "branchConcurrentLimit": 4,
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true
}
